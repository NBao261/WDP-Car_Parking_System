# API Endpoints
# URL trỏ đến Backend API (có bao gồm /api/v1)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Thông tin Ứng dụng
# Tên của dự án/hệ thống
VITE_APP_NAME=SPMS
# Môi trường chạy (development, staging, production)
VITE_APP_ENV=development

# Real-time WebSocket
# URL trỏ đến Backend Server cho các kết nối Socket.IO
VITE_SOCKET_URL=http://localhost:5000
