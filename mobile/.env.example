# ─── Smart Parking Mobile ───────────────────────────
# Copy this file to .env and fill in your values

# API URL (bao gồm /api/v1)
EXPO_PUBLIC_API_URL=http://localhost:5000/api/v1

# Google Maps API Key (bắt buộc cho Android, tuỳ chọn cho iOS)
# Lấy key tại: https://console.cloud.google.com/apis/credentials
# Cần enable: Maps SDK for Android, Maps SDK for iOS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
