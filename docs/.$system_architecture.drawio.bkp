        <mxCell id="l_pay_callback" value="IPN Callback" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_pay_callback">
          <mxGeometry x="0.2" relative="1" as="geometry">
