        <mxCell id="l_alpr_response" value="HTTP Response (OCR Text)" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_alpr_response">
          <mxGeometry x="0.1" relative="1" as="geometry">
            <mxPoint y="10" as="offset"/>
          </mxGeometry>
        </mxCell>


        <!-- 4. Core Server <-> MongoDB -->
