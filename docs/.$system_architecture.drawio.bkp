<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.2.9 Chrome/140.0.7339.249 Electron/38.7.2 Safari/537.36" version="29.2.9">
  <diagram id="system_arch" name="System Architecture">
    <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ─── CONTAINERS / GROUPS ─── -->
        <!-- Client Layer Container -->
        <mxCell id="g1_box" value="Client / Frontend Layer" style="rounded=0;fillColor=none;strokeColor=#999999;strokeWidth=1;dashed=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=8;fontStyle=1;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="770" height="170" as="geometry"/>
        </mxCell>

        <!-- Backend Layer Container -->
        <mxCell id="g2_box" value="Backend / Application Layer" style="rounded=0;fillColor=none;strokeColor=#999999;strokeWidth=1;dashed=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=8;fontStyle=1;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="770" height="190" as="geometry"/>
        </mxCell>

        <!-- Data Layer Container -->
        <mxCell id="g3_box" value="Data &amp;amp; Storage Layer" style="rounded=0;fillColor=none;strokeColor=#999999;strokeWidth=1;dashed=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=8;fontStyle=1;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="370" height="170" as="geometry"/>
        </mxCell>

        <!-- Third-Party Container -->
        <mxCell id="g4_box" value="Third-Party Integration" style="rounded=0;fillColor=none;strokeColor=#999999;strokeWidth=1;dashed=1;align=left;verticalAlign=top;spacingLeft=15;spacingTop=8;fontStyle=1;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="440" y="500" width="370" height="170" as="geometry"/>
        </mxCell>


        <!-- ─── COMPONENTS ─── -->
        <!-- Web App -->
        <mxCell id="c_web" value="React Web App&#xa;(Staff, Manager, Admin Dashboard)&#xa;[Vite / TypeScript]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Mobile App -->
        <mxCell id="c_mobile" value="Mobile App&#xa;(Driver Booking, QR Code)&#xa;[React Native]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="90" width="220" height="80" as="geometry"/>
        </mxCell>

        <!-- Node.js Backend -->
        <mxCell id="c_server" value="Core Backend Server&#xa;(Authentication, Shift Selection, Fees, DB CRUD, Sessions)&#xa;[Node.js / Express / TypeScript]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="310" width="270" height="100" as="geometry"/>
        </mxCell>

        <!-- Python ALPR Service -->
        <mxCell id="c_alpr" value="ALPR Service&#xa;(YOLOv8 Plate &amp;amp; OCR Detection)&#xa;[Python / FastAPI]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="320" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- MongoDB Database -->
        <mxCell id="c_db" value="MongoDB&#xa;(Collections: Users, Sessions, Reservations, Pricing)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- Cloud Storage -->
        <mxCell id="c_storage" value="Cloud Storage&#xa;(Check-in/out Images)" style="ellipse;shape=cloud;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="550" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- Payment Gateways -->
        <mxCell id="c_payment" value="Payment Gateways&#xa;(MoMo / ZaloPay)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="550" width="130" height="80" as="geometry"/>
        </mxCell>

        <!-- LLM API Chatbot -->
        <mxCell id="c_llm" value="AI Assistant API&#xa;(Gemini / OpenAI)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="550" width="130" height="80" as="geometry"/>
        </mxCell>


        <!-- ─── CONNECTIONS / ARROWS ─── -->
        
        <!-- 1. Web App <-> Core Server (HTTP Request / Response & WebSocket) -->
        <!-- HTTP Request -->
        <mxCell id="e_web_request" edge="1" parent="1" source="c_web" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.15;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_web_request" value="HTTP Request" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_web_request">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="-40" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- HTTP Response -->
        <mxCell id="e_web_response" edge="1" parent="1" source="c_server" target="c_web" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=0.35;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_web_response" value="HTTP Response" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_web_response">
          <mxGeometry x="0.1" relative="1" as="geometry">
            <mxPoint x="-15" y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- WebSocket connection (Duplex) -->
        <mxCell id="e_web_ws" edge="1" parent="1" source="c_web" target="c_server" style="endArrow=classic;startArrow=classic;endFill=1;startFill=1;strokeColor=#000000;strokeWidth=1.5;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.55;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="l_web_ws" value="WebSocket (Duplex)&#xa;(Real-time ALPR stream)" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=1;" vertex="1" connectable="0" parent="e_web_ws">
          <mxGeometry x="-0.15" relative="1" as="geometry">
            <mxPoint x="60" y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>


        <!-- 2. Mobile App <-> Core Server (HTTP Request / Response) -->
        <!-- HTTP Request -->
        <mxCell id="e_mobile_request" edge="1" parent="1" source="c_mobile" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.75;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="595" y="240"/>
              <mxPoint x="493" y="240"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="l_mobile_request" value="HTTP Request" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_mobile_request">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="-40" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- HTTP Response -->
        <mxCell id="e_mobile_response" edge="1" parent="1" source="c_server" target="c_mobile" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=0.9;exitY=0;exitDx=0;exitDy=0;entryX=0.75;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="533" y="250"/>
              <mxPoint x="705" y="250"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="l_mobile_response" value="HTTP Response" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_mobile_response">
          <mxGeometry x="0.1" relative="1" as="geometry">
            <mxPoint x="40" y="-12" as="offset"/>
          </mxGeometry>
        </mxCell>


        <!-- 3. Core Server <-> Python ALPR Service (HTTP Request / Response) -->
        <!-- POST Image Request -->
        <mxCell id="e_alpr_request" edge="1" parent="1" source="c_server" target="c_alpr" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0;exitY=0.25;exitDx=0;exitDy=0;entryX=1;entryY=0.25;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry"/>
