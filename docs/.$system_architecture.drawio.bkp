        <mxCell id="l_storage_url" value="Image URL" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_storage_url">
          <mxGeometry x="0.1" relative="1" as="geometry">
            <mxPoint x="25" y="10" as="offset"/>
          </mxGeometry>
        </mxCell>


        <!-- 6. Core Server <-> Payment Gateways -->
        <!-- Payment Request -->
        <mxCell id="e_pay_request" edge="1" parent="1" source="c_server" target="c_payment" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="479" y="470"/>
              <mxPoint x="513" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="l_pay_request" value="Request payment" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_pay_request">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint x="-35" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- IPN Callback -->
        <mxCell id="e_pay_callback" edge="1" parent="1" source="c_payment" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.8;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="578" y="480"/>
              <mxPoint x="506" y="480"/>
            </Array>
