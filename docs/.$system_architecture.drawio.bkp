        <mxCell id="e_db_query" edge="1" parent="1" source="c_server" target="c_db" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0.08;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
