        <mxCell id="l_alpr_request" value="HTTP POST (Image)" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_alpr_request">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- OCR Text Response -->
        <mxCell id="e_alpr_response" edge="1" parent="1" source="c_alpr" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry"/>
