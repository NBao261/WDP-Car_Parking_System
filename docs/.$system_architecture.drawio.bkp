        <!-- Chat Completion -->
        <mxCell id="e_llm_response" edge="1" parent="1" source="c_llm" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=0.75;exitY=0;exitDx=0;exitDy=0;entryX=0.95;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
