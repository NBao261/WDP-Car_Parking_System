              <mxPoint x="178" y="480"/>
              <mxPoint x="358" y="480"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="l_db_data" value="Data Return" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_db_data">
          <mxGeometry x="0.15" relative="1" as="geometry">
            <mxPoint x="20" y="10" as="offset"/>
          </mxGeometry>
        </mxCell>


        <!-- 5. Core Server <-> Cloud Storage -->
        <!-- S3 Upload -->
        <mxCell id="e_storage_upload" edge="1" parent="1" source="c_server" target="c_storage" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;exitX=0.45;exitY=1;exitDx=0;exitDy=0;entryX=0.25;entryY=0.1;entryDx=0;entryDy=0;entryPerimeter=1;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="412" y="470"/>
              <mxPoint x="283" y="470"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="l_storage_upload" value="Upload Photo" style="edgeLabel;align=center;verticalAlign=middle;resizable=0;points=[];fontSize=8;fontStyle=0;" vertex="1" connectable="0" parent="e_storage_upload">
          <mxGeometry x="-0.1" relative="1" as="geometry">
            <mxPoint x="-35" y="-10" as="offset"/>
          </mxGeometry>
        </mxCell>

        <!-- S3 URL -->
        <mxCell id="e_storage_url" edge="1" parent="1" source="c_storage" target="c_server" style="endArrow=block;endFill=1;strokeColor=#000000;strokeWidth=1.2;dashed=1;exitX=0.75;exitY=0.1;exitDx=0;exitDy=0;exitPerimeter=1;entryX=0.55;entryY=1;entryDx=0;entryDy=0;edgeStyle=orthogonalEdgeStyle;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="348" y="480"/>
              <mxPoint x="439" y="480"/>
            </Array>
          </mxGeometry>
